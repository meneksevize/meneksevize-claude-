# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi girin.
# Şifre hash'i üretmek için: npm run hash-password -- "sifreniz"

PORT=4000
NODE_ENV=development

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

SESSION_SECRET=degistirin-bu-cok-uzun-ve-rastgele-bir-metin-olmali

# Boş bırakılırsa server/data/app.db kullanılır.
# Render gibi bir sunucuda kalıcı disk mount noktasına işaret edecek şekilde ayarlayın, örn: /var/data/app.db
DB_PATH=

# E-posta bildirimleri (Resend) — admin panelinde "Genel Ayarlar"dan da açık olması gerekir.
# Kurulum: resend.com'da ücretsiz hesap açıp API Keys bölümünden bir anahtar üretin.
RESEND_API_KEY=
# Opsiyonel: kendi domain'inizi Resend'de doğruladıysanız buraya yazın, aksi halde
# varsayılan (onboarding@resend.dev) kullanılır.
RESEND_FROM=

# Sitenin herkese açık adresi — iyzico'nun ödeme sonucunu geri göndereceği
# callback URL'ini oluşturmak için kullanılır. Prod'da https://meneksevize.com
# olmalı; boş bırakılırsa gelen isteğin host'u kullanılır (yerel test için yeterli).
SITE_URL=https://meneksevize.com

# iyzico ödeme entegrasyonu — hesap açılana kadar boş bırakın, ödeme
# endpoint'leri otomatik olarak "henüz aktif değil" mesajı döner, site geri
# kalanı etkilenmez. Hesap açtıktan sonra iyzico Merchant panelinden
# (Ayarlar > API Anahtarları) alınan gerçek anahtarları buraya girin.
# Test için: https://sandbox-merchant.iyzipay.com üzerinden sandbox hesabı/anahtarları alınabilir.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Sandbox: https://sandbox-api.iyzipay.com — Canlı: https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
